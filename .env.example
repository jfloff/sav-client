# SAV2 credentials
SAV_BASE_URL=https://sav2.fpb.pt   # optional, this is the default
SAV_USERNAME=your_username
SAV_PASSWORD=your_password
CLUB_STAMP_PATH=/path/to/carimbo.png  # required for mod1 uploads (enrollment create with PDFs; enrollment update with a PDF)

DOCAI_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_CLASSIFIER_PROCESSOR_ID=
DOCAI_EXAME_MEDICO_PROCESSOR_ID=
DOCAI_FPB_MODELO_1_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Optional tuning
SAV_TIMEOUT=30        # request timeout in seconds
SAV_LOG_LEVEL=WARNING # DEBUG / INFO / WARNING / ERROR
